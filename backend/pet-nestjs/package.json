{
  "name": "pet-nestjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "10.4.22",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/platform-express": "10.4.22",
    "@prisma/client": "5.22.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "minio": "8.0.7",
    "multer": "2.1.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@types/express": "4.17.25",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.25",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "ts-jest": "29.4.6",
    "typescript": "5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "testEnvironment": "node"
  }
}
